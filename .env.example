# ─────────────────────────────────────────────
#  monday-bi-agent — environment variables
#  Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# Monday.com Personal API Token
# Get it from: Monday.com → Profile → Developer → My Access Tokens
MONDAY_API_TOKEN=your_monday_api_token_here

# Monday.com Board IDs  (visible in the URL when you open a board)
MONDAY_DEALS_BOARD_ID=your_deals_board_id
MONDAY_WORK_ORDERS_BOARD_ID=your_work_orders_board_id

# Groq API Key  (get it from https://console.groq.com)
# OR xAI Grok key from https://console.x.ai
GROK_API_KEY=your_groq_or_xai_api_key_here

# Grok model — leave blank to auto-detect based on your API key prefix:
#   gsk_... (Groq)  → llama-3.3-70b-versatile
#   xai-... (xAI)   → grok-3-beta
GROK_MODEL=

# FastAPI server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend origin for CORS (update if deploying)
FRONTEND_ORIGIN=http://localhost:5173
